{
  "name": "erp-ui",
  "version": "1.0.0",
  "description": "ERP Faturador - UI Desktop",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "test": "react-scripts test --passWithNoTests",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "@reduxjs/toolkit": "^1.9.7",
    "axios": "^1.6.2",
    "electron-squirrel-startup": "^1.1.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "react-scripts": "5.0.1",
    "typescript": "^5.3.3",
    "electron": "^27.0.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
